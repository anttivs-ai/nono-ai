{
  // Common ancestor for all nono-ai CLI profiles. Per-CLI profiles extend
  // this and add their tool-specific filesystem and network rules.
  //
  // Policy groups (groups.include) are shipped by nono itself; see
  // `nono profile show default` for what each pre-defined group grants/denies.

  "$schema": "./nono-profile.schema.json",
  "extends": "default",
  "meta": { "name": "nono-ai-base" },

  "groups": {
    "include": [
      "node_runtime",            // read access to brew node + global modules
      "homebrew",                // read access to /opt/homebrew (covers `op` binary)
      "user_tools",
      "deny_credentials",        // ~/.aws/credentials, ~/.gnupg, etc.
      "deny_keychains_macos",    // macOS keychain databases
      "deny_browser_data_macos", // Safari, Chrome, Firefox profiles
      "deny_macos_private",      // /private system areas not otherwise needed
      "deny_shell_history",      // ~/.zsh_history, ~/.bash_history
      "deny_shell_configs"       // ~/.zshrc, ~/.bashrc — agents must not edit these
    ]
  },

  "filesystem": {
    // Installed CLIs live here, immutable at runtime so a compromised CLI
    // can't rewrite its own binaries. `make update` rebuilds the tree.
    "read": ["$HOME/.local/share/nono-ai/npm"],

    // Working directory for AI projects, same convention as colima-docker-ai.
    "allow": ["$HOME/Documents/ai"]
  },

  "environment": {
    "allow_vars": [
      "PATH", "HOME", "USER", "SHELL", "TERM",
      "LANG", "LC_*",
      "TMPDIR",
      "OLLAMA_HOST"
    ]
  },

  // nono fetches the 1Password service-account token directly via the
  // macOS desktop app (the auth model the user already uses) and injects
  // it as OP_SERVICE_ACCOUNT_TOKEN. The token never appears on the
  // command line, in env files, or in shell history. Edit this key to
  // point at a different vault entry.
  "env_credentials": {
    "op://Private/1password-EU-avs-business/CLI token": "OP_SERVICE_ACCOUNT_TOKEN"
  },

  "network": {
    "allow_domain": [
      "my.1password.com",
      "events.1password.com"
    ],
    // Loopback to host services. macOS loopback IS the host's loopback
    // here (no VM bridge), so these reach Ollama / avs-rag directly.
    "open_port": [11434, 8765]
  }
}
