{
  // Profile for Claude Code, sharing all state with the host's host-installed
  // Claude Code (same ~/.claude.json, same ~/.claude/). The only differences
  // vs. host-direct execution are: kernel-enforced filesystem allow-list,
  // network allow-list, and credential injection.

  "$schema": "./nono-profile.schema.json",
  "extends": "nono-ai-base",
  "meta": { "name": "nono-ai-claude" },

  // nono ships a pre-built Claude Code group with sensible macOS defaults
  // (Claude Code's cache and config locations beyond the obvious ones).
  "groups": { "include": ["claude_code_macos"] },

  "filesystem": {
    "allow": [
      "$HOME/.claude",                // OAuth credentials + project state
      "$HOME/.config/claude-code"     // tolerated if Claude moves config here
    ],
    "allow_file": ["$HOME/.claude.json"]
  },

  "network": {
    // Bundled network profile covers api.anthropic.com and related upstream
    // hosts. Adding `claude.ai` explicitly for the OAuth login flow is
    // belt-and-suspenders in case the bundled profile narrows to API only.
    "network_profile": "claude-code",
    "allow_domain": ["claude.ai"]
  }
}
